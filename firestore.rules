rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return profile().data.role;
    }

    function scopeKeys() {
      return profile().data.scopeKeys == null ? [] : profile().data.scopeKeys;
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    function isSuperAdmin() {
      return signedIn() &&
        profile().data.status != "blocked" &&
        (role() in ["admin", "super_admin"] || ("platform:super_admin" in scopeKeys()));
    }

    function isGroupAdmin(groupId) {
      return signedIn() &&
        profile().data.status != "blocked" &&
        (("group:" + groupId + ":group_admin") in scopeKeys());
    }

    function isInstituteAdmin(instituteId) {
      return signedIn() &&
        profile().data.status != "blocked" &&
        (("institute:" + instituteId + ":institute_admin") in scopeKeys());
    }

    function isTeacher() {
      return signedIn() && role() == "teacher" && profile().data.status in ["approved", "active"];
    }

    function isStudent() {
      return signedIn() && role() == "student" && profile().data.status == "active";
    }

    function teacherSubjectIds() {
      return profile().data.teacherSubjectIds == null ? [] : profile().data.teacherSubjectIds;
    }

    match /users/{uid} {
      allow create: if signedIn() &&
        request.auth.uid == uid &&
        request.resource.data.role in ["student", "teacher"] &&
        false;
      allow read: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow update: if isAdmin() || (
        signedIn() &&
        request.auth.uid == uid &&
        (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["role", "status", "batchIds", "teacherSubjectIds", "memberships", "scopeKeys"]) ||
          (
            request.resource.data.lastClaimedInviteToken is string &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.lastClaimedInviteToken)).data.status == "claimed" &&
            get(/databases/$(database)/documents/invites/$(request.resource.data.lastClaimedInviteToken)).data.claimedBy == request.auth.uid
          )
        )
      );
      allow delete: if isAdmin();
    }

    match /memberships/{id} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSuperAdmin() || (
        signedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.inviteToken is string &&
        get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.status == "claimed" &&
        get(/databases/$(database)/documents/invites/$(request.resource.data.inviteToken)).data.claimedBy == request.auth.uid
      );
      allow update, delete: if isSuperAdmin();
    }

    match /instituteGroups/{id} {
      allow read: if isSuperAdmin() || isGroupAdmin(id);
      allow write: if isSuperAdmin();
    }

    match /institutes/{id} {
      allow read: if isSuperAdmin() || isInstituteAdmin(id) || (resource.data.groupId is string && isGroupAdmin(resource.data.groupId));
      allow write: if isSuperAdmin();
    }

    match /invites/{token} {
      allow read: if isSuperAdmin() || (signedIn() && resource.data.status == "active");
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        signedIn() &&
        resource.data.status == "active" &&
        request.resource.data.status == "claimed" &&
        request.resource.data.claimedBy == request.auth.uid
      );
    }

    match /billingAccounts/{id} {
      allow read: if isSuperAdmin() ||
        (resource.data.groupId is string && isGroupAdmin(resource.data.groupId)) ||
        (resource.data.instituteId is string && isInstituteAdmin(resource.data.instituteId));
      allow write: if isSuperAdmin();
    }

    match /creditLedger/{id} {
      allow read, write: if isSuperAdmin();
    }

    match /platformSettings/{id} {
      allow read: if signedIn();
      allow write: if isSuperAdmin();
    }

    match /auditLogs/{id} {
      allow read, write: if isSuperAdmin();
    }

    match /exams/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /subjects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chapters/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{id} {
      allow read: if signedIn() && (
        resource.data.status == "published" ||
        isAdmin() ||
        (isTeacher() && resource.data.subjectId in teacherSubjectIds())
      );
      allow create: if isAdmin() || (
        isTeacher() &&
        request.resource.data.authorUid == request.auth.uid &&
        request.resource.data.subjectId in teacherSubjectIds()
      );
      allow update: if isAdmin() || (
        isTeacher() &&
        resource.data.subjectId in teacherSubjectIds() &&
        request.resource.data.subjectId in teacherSubjectIds()
      );
      allow delete: if isAdmin();
    }

    match /imports/{id} {
      allow read: if isAdmin() || (signedIn() && resource.data.createdBy == request.auth.uid);
      allow create: if isAdmin() || (isTeacher() && request.resource.data.createdBy == request.auth.uid);
      allow update: if isAdmin() || (isTeacher() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /tests/{id} {
      allow read: if signedIn() && (
        resource.data.status == "published" ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /attempts/{id} {
      allow create: if isStudent() && request.resource.data.studentUid == request.auth.uid;
      allow read: if isAdmin() || (signedIn() && resource.data.studentUid == request.auth.uid);
      allow update: if isAdmin() || (
        isStudent() &&
        resource.data.studentUid == request.auth.uid &&
        request.resource.data.studentUid == request.auth.uid &&
        resource.data.status == "in-progress" &&
        request.resource.data.status in ["in-progress", "submitted"]
      );
      allow delete: if isAdmin();
    }

    match /batches/{id} {
      allow read: if isAdmin() || (isStudent() && request.auth.uid in resource.data.studentIds);
      allow write: if isAdmin();
    }

    match /flags/{id} {
      allow create: if signedIn() && request.resource.data.createdBy == request.auth.uid;
      allow read, update, delete: if isAdmin();
    }
  }
}
