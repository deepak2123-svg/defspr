rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /question-media/{uid}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid && request.resource.size < 10 * 1024 * 1024;
    }

    match /imports/{uid}/{allPaths=**} {
      allow read, write: if signedIn() && request.auth.uid == uid && request.resource.size < 25 * 1024 * 1024;
    }
  }
}
